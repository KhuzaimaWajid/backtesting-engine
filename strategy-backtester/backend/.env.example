# Copy this file to .env and adjust as needed.

# Postgres connection string. Matches docker-compose.yml's `postgres` service
# by default; change the host/port if you're running Postgres yourself.
DATABASE_URL=postgresql://backtest:backtest@localhost:5432/backtest

# Set to true ONLY if you have no outbound network access and want to
# exercise the pipeline with deterministic fake data instead of Yahoo
# Finance. Never enable this for anything that should reflect real markets.
USE_SYNTHETIC_DATA=false
